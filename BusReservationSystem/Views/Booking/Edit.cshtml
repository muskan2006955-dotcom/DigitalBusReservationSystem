@model BusReservationSystem.Models.Booking

@{
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
    ViewData["Title"] = "Edit Booking";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    :root {
        --primary-dark: #0f172a;
        --accent-orange: #f59e0b;
        --accent-blue: #3b82f6;
        --card-bg: #ffffff;
    }

    body {
        background-color: #f1f5f9;
        font-family: 'Inter', sans-serif;
    }

    .booking-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        background: var(--card-bg);
        overflow: hidden;
    }

    .booking-header {
        background: var(--primary-dark);
        color: white;
        padding: 25px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .form-section-title {
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #64748b;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 10px;
    }

    .select2-container--default .select2-selection--single {
        height: 50px !important;
        background: #f8fafc !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 12px !important;
        padding: 10px !important;
    }

    .form-control {
        height: 50px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    .fare-panel {
        background: #fffbeb;
        border-radius: 15px;
        padding: 25px;
        border: 1.5px dashed var(--accent-orange);
    }

    .fare-value {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--primary-dark);
        border: none;
        background: transparent;
        width: 100%;
        text-align: center;
    }

    .btn-update {
        background: var(--primary-dark);
        color: white;
        border-radius: 12px;
        padding: 18px 50px;
        font-weight: 700;
        border: none;
        transition: 0.3s;
        width: 100%;
    }

        .btn-update:hover {
            background: #1e293b;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.3);
        }
</style>

<div class="container py-5">
    <div class="card booking-card">
        <div class="booking-header">
            <h4><i class="fa fa-edit me-2 text-warning"></i> Modify Booking #@Model.BookingId</h4>
            <span class="badge bg-warning text-dark px-3 py-2 fw-bold">Edit Mode</span>
        </div>

        <div class="card-body p-4 p-lg-5">
            <form asp-action="Edit" method="post" id="editForm">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="BookingId" />
                <input type="hidden" asp-for="CustomerId" id="hfCustomerId" />
                <input type="hidden" asp-for="BookedBy" />
                <input type="hidden" asp-for="BookingDate" />

                <div class="row g-5">
                    <div class="col-lg-6 border-end">
                        <div class="form-section-title">
                            <i class="fa fa-user-edit me-2"></i> Passenger Details
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Customer (by CNIC)</label>
                            <select class="form-control" id="ddlCnic" asp-items="ViewBag.CustomerCnicList">
                                <option></option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Customer (by Name)</label>
                            <select class="form-control" id="ddlName" asp-items="ViewBag.CustomerNameList">
                                <option></option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Travel Date</label>
                            <input asp-for="TravelDate" type="date" class="form-control" id="txtTravelDate" required />
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="form-section-title">
                            <i class="fa fa-bus me-2"></i> Trip Information
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Bus & Route</label>
                            <select asp-for="BusId" class="form-control" id="ddlBus" asp-items="ViewBag.BusId" onchange="loadSeats()" required>
                                <option></option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Seat Number</label>
                            <select asp-for="SeatNumber" class="form-control" id="ddlSeats" required>
                                <option value="@Model.SeatNumber">Seat @Model.SeatNumber (Current)</option>
                            </select>
                        </div>

                        <div class="mt-4 pt-2">
                            <button type="button" onclick="calculateFare()" class="btn btn-outline-warning w-100 py-2 fw-bold border-2">
                                <i class="fa fa-sync-alt me-2"></i> Re-Calculate Fare
                            </button>
                        </div>
                    </div>
                </div>

                <div class="fare-panel mt-5">
                    <div class="row text-center align-items-center">
                        <div class="col-md-3 border-end">
                            <label class="text-muted small fw-bold">BASE FARE</label>
                            <input asp-for="BaseFare" id="txtBase" class="fare-value" readonly />
                        </div>
                        <div class="col-md-3 border-end">
                            <label class="text-muted small fw-bold">DISCOUNT</label>
                            <input asp-for="DiscountAmount" id="txtDisc" class="fare-value text-danger" readonly />
                        </div>
                        <div class="col-md-3 border-end">
                            <label class="text-muted small fw-bold">TAXES</label>
                            <input asp-for="TaxAmount" id="txtTax" class="fare-value" readonly />
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted small fw-bold text-primary">FINAL TOTAL</label>
                            <input asp-for="FinalAmount" id="txtFinal" class="fare-value text-primary fs-3" readonly />
                        </div>
                    </div>
                </div>

                <div class="text-center mt-5">
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-light px-5 py-3 fw-bold rounded-pill">Cancel</a>
                        <button type="submit" class="btn btn-update shadow-lg rounded-pill" style="width: auto;">
                            <i class="fa fa-save me-2"></i> Save Changes
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
            // Initialize Select2
            $('#ddlCnic').select2({ placeholder: "Search CNIC...", allowClear: true, width: '100%' });
            $('#ddlName').select2({ placeholder: "Search Name...", allowClear: true, width: '100%' });
            $('#ddlBus').select2({ placeholder: "Select Bus...", allowClear: true, width: '100%' });

            // Set Initial Values from Model
            var initialCustomerId = '@Model.CustomerId';
            $('#ddlCnic').val(initialCustomerId).trigger('change.select2');
            $('#ddlName').val(initialCustomerId).trigger('change.select2');

            // Sync Dropdowns
            $('#ddlCnic, #ddlName').on('select2:select', function (e) {
                var selectedId = $(this).val();
                $('#hfCustomerId').val(selectedId);
                $('#ddlCnic').val(selectedId).trigger('change.select2');
                $('#ddlName').val(selectedId).trigger('change.select2');
                calculateFare();
            });

            // Date validation
            document.getElementById('txtTravelDate').min = new Date().toISOString().split("T")[0];
        });

        async function loadSeats() {
            const busId = document.getElementById('ddlBus').value;
            const seatDrop = document.getElementById('ddlSeats');
            if (!busId) return;

            try {
                const response = await fetch(`/Booking/GetAvailableSeats?busId=${busId}`);
                const seats = await response.json();

                // Keep the current seat as an option even if it's "booked"
                seatDrop.innerHTML = `<option value="@Model.SeatNumber">Seat @Model.SeatNumber (Current)</option>`;

                seats.forEach(s => {
                    if(s.val != '@Model.SeatNumber') {
                        let opt = document.createElement("option");
                        opt.value = s.val;
                        opt.text = "Seat " + s.val;
                        seatDrop.appendChild(opt);
                    }
                });
            } catch (err) { console.error("Error loading seats:", err); }
        }

        async function calculateFare() {
            const bId = document.getElementById('ddlBus').value;
            const cId = document.getElementById('hfCustomerId').value;
            if (!bId || !cId) return;

            try {
                const response = await fetch(`/Booking/CalculateFare?busId=${bId}&customerId=${cId}`);
                const data = await response.json();
                if(data.error) return;

                document.getElementById('txtBase').value = data.baseFare;
                document.getElementById('txtDisc').value = data.discount;
                document.getElementById('txtTax').value = data.taxAmount;
                document.getElementById('txtFinal').value = data.finalAmount;
            } catch (err) { console.error("Fare error:", err); }
        }
    </script>
}