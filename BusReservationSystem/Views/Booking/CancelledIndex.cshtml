@model IEnumerable<BusReservationSystem.Models.Booking>

@{
    ViewData["Title"] = "Cancelled Bookings";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<style>
    /* Filter Bar Styling */
    .filter-card {
        background: #f8fafc;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 20px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .cancellation-card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        background: white;
    }

    .table thead th {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.5px;
        padding: 15px;
    }

    .status-badge {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .bg-soft-danger {
        background: #fbe9e7;
        color: #d32f2f;
        border: 1px solid #ffccbc;
    }

    .refund-text {
        color: #15803d;
        font-weight: 800;
    }

    .id-badge {
        background: #f1f5f9;
        color: #64748b;
        font-weight: bold;
        padding: 4px 8px;
        border-radius: 5px;
        font-size: 12px;
        border: 1px solid #e2e8f0;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold"><i class="fa fa-ban text-danger me-2"></i> Cancelled Bookings</h2>
        <span class="badge bg-danger px-3 py-2 shadow-sm">Total Count: @Model.Count()</span>
    </div>

    <div class="filter-card">
        <form method="get" asp-action="CancelledIndex" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="small fw-bold text-muted mb-1">Search Passenger (Name/CNIC)</label>
                <input type="text" name="searchTerm" class="form-control form-control-sm shadow-none"
                       placeholder="Enter details..." value="@Context.Request.Query["searchTerm"]">
            </div>
            <div class="col-md-3">
                <label class="small fw-bold text-muted mb-1">Cancellation Date</label>
                <input type="date" name="cancelDate" class="form-control form-control-sm shadow-none"
                       value="@Context.Request.Query["cancelDate"]">
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-danger btn-sm px-4 flex-grow-1">
                    <i class="fa fa-search me-1"></i> Filter
                </button>
                <a asp-action="CancelledIndex" class="btn btn-outline-secondary btn-sm px-3">
                    Reset
                </a>
            </div>
        </form>
    </div>

    <div class="card cancellation-card overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Booking ID</th>
                            <th>Customer Details</th>
                            <th>Bus & Seat</th>
                            <th>Cancellation Timing</th>
                            <th>Refund Issued</th>
                            <th class="text-center pe-4">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4"><span class="id-badge">#BK-@item.BookingId</span></td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Customer?.CustomerName</div>
                                    <div class="small text-muted">@item.Customer?.IdproofNumber</div>
                                </td>
                                <td>
                                    <div class="small">
                                        <i class="fa fa-bus me-1 text-muted"></i> @item.Bus?.BusNumber <br />
                                        <i class="fa fa-chair me-1 text-muted"></i> Seat @item.SeatNumber
                                    </div>
                                </td>
                                <td>
                                    <div class="text-dark fw-bold" style="font-size: 13px;">
                                        @item.CancellationDate?.ToString("dd MMM, yyyy")
                                    </div>
                                    <div class="text-muted small">
                                        <i class="far fa-clock me-1"></i> @item.CancellationDate?.ToString("hh:mm tt")
                                    </div>
                                </td>
                                <td>
                                    <span class="refund-text">Rs. @(item.RefundAmount?.ToString("N0") ?? "0")</span>
                                </td>
                                <td class="text-center pe-4">
                                    <span class="status-badge bg-soft-danger">
                                        <i class="fa fa-times-circle me-1"></i> Cancelled
                                    </span>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fa fa-search fa-3x mb-3 opacity-25"></i><br />
                                    No records found matching your search.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>