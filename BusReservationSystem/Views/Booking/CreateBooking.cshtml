@model BusReservationSystem.Models.BookingViewModel
@{
    ViewData["Title"] = "Book Ticket";
    Layout = "~/Views/Shared/EmployeeLayout.cshtml";
}

<div class="container-fluid">
    <h2>🎫 Book New Ticket</h2>
    <hr />

    <div class="row">
        <!-- Customer Information -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Customer Information</h5>
                </div>
                <div class="card-body">
                    <form id="bookingForm">
                        <div class="mb-3">
                            <label class="form-label">Customer Name *</label>
                            <input type="text" class="form-control" id="CustomerName" required />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Age *</label>
                                <input type="number" class="form-control" id="Age" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Gender *</label>
                                <select class="form-select" id="Gender" required>
                                    <option value="">Select</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone Number *</label>
                            <input type="text" class="form-control" id="PhoneNumber" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">ID Proof Number *</label>
                            <input type="text" class="form-control" id="IdproofNumber" required />
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Bus Selection -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5>Bus Selection</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Select Bus *</label>
                        <select class="form-select" id="BusSelect" onchange="loadSeats()">
                            <option value="">Select Bus</option>
                            @foreach (var bus in Model.Buses)
                            {
                                <option value="@bus.BusId"
                                        data-type="@bus.BusType"
                                        data-distance="@bus.DistanceInKm"
                                        data-route="@bus.StartingPoint - @bus.DestinationPoint">
                                    @bus.BusCode - @bus.BusType
                                </option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Travel Date *</label>
                        <input type="date" class="form-control" id="TravelDate" required />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Seat Selection -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5>Available Seats</h5>
                </div>
                <div class="card-body">
                    <div id="seatContainer" class="row">
                        <p class="text-muted">Please select a bus to see available seats</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Fare Calculation -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-warning">
                    <h5>Fare Details</h5>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <td>Base Fare:</td>
                            <td id="BaseFare">0.00</td>
                        </tr>
                        <tr>
                            <td>Discount:</td>
                            <td id="DiscountAmount">0.00</td>
                        </tr>
                        <tr>
                            <td>Tax:</td>
                            <td id="TaxAmount">0.00</td>
                        </tr>
                        <tr class="table-primary">
                            <td><strong>Final Amount:</strong></td>
                            <td><strong id="FinalAmount">0.00</strong></td>
                        </tr>
                    </table>
                    <button class="btn btn-success btn-lg" onclick="confirmBooking()">
                        ✅ Confirm Booking
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedSeat = null;
        let selectedBus = null;

        function loadSeats() {
            const busId = document.getElementById('BusSelect').value;
            if (busId) {
                fetch(`/booking/GetAvailableSeats/${busId}`)
                    .then(response => response.json())
                    .then(data => {
                        const container = document.getElementById('seatContainer');
                        container.innerHTML = '';
                        data.forEach(seat => {
                            container.innerHTML += `
                                <div class="col-2 mb-2">
                                    <button class="btn btn-outline-primary w-100"
                                            onclick="selectSeat(${seat.seatId}, '${seat.seatNumber}')">
                                        ${seat.seatNumber}
                                    </button>
                                </div>
                            `;
                        });
                    });
            }
        }

        function selectSeat(seatId, seatNumber) {
            selectedSeat = seatId;
            document.querySelectorAll('#seatContainer button').forEach(btn => {
                btn.classList.remove('btn-primary');
                btn.classList.add('btn-outline-primary');
            });
            event.target.classList.remove('btn-outline-primary');
            event.target.classList.add('btn-primary');
        }

        function calculateFare() {
            const busSelect = document.getElementById('BusSelect');
            const age = parseInt(document.getElementById('Age').value);

            if (busSelect.value && age) {
                const bus = busSelect.options[busSelect.selectedIndex];
                const distance = parseFloat(bus.getAttribute('data-distance'));
                const busType = bus.getAttribute('data-type');

                fetch(`/booking/CalculateFare`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        SelectedBus: { BusType: busType, DistanceInKm: distance },
                        Customer: { Age: age }
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('BaseFare').textContent = data.baseFare.toFixed(2);
                        document.getElementById('DiscountAmount').textContent = data.discountAmount.toFixed(2);
                        document.getElementById('TaxAmount').textContent = data.taxAmount.toFixed(2);
                        document.getElementById('FinalAmount').textContent = data.finalAmount.toFixed(2);
                    }
                });
            }
        }

        function confirmBooking() {
            if (!selectedSeat) {
                alert('Please select a seat');
                return;
            }

            const bookingData = {
                Customer: {
                    CustomerName: document.getElementById('CustomerName').value,
                    Age: parseInt(document.getElementById('Age').value),
                    Gender: document.getElementById('Gender').value,
                    PhoneNumber: document.getElementById('PhoneNumber').value,
                    IdproofNumber: document.getElementById('IdproofNumber').value
                },
                SelectedBus: {
                    BusId: document.getElementById('BusSelect').value,
                    BusType: document.getElementById('BusSelect').options[document.getElementById('BusSelect').selectedIndex].getAttribute('data-type'),
                    DistanceInKm: parseFloat(document.getElementById('BusSelect').options[document.getElementById('BusSelect').selectedIndex].getAttribute('data-distance'))
                },
                SeatId: selectedSeat,
                TravelDate: document.getElementById('TravelDate').value,
                BaseFare: parseFloat(document.getElementById('BaseFare').textContent),
                DiscountAmount: parseFloat(document.getElementById('DiscountAmount').textContent),
                TaxAmount: parseFloat(document.getElementById('TaxAmount').textContent),
                FinalAmount: parseFloat(document.getElementById('FinalAmount').textContent)
            };

            fetch('/booking/CreateBooking', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bookingData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Booking Successful! Booking ID: ' + data.bookingId);
                    window.location.href = '/booking/Search';
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }

        document.getElementById('Age').addEventListener('change', calculateFare);
        document.getElementById('BusSelect').addEventListener('change', calculateFare);
    </script>
}