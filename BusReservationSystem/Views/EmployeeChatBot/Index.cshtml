@{
    ViewData["Title"] = "Galaxy AI";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="chat-wrapper">
    <div class="chat-card">
        <div class="chat-header">
            <div class="d-flex align-items-center">
                <div class="bot-icon">
                    <i class="fas fa-bolt"></i>
                </div>
                <div>
                    <h5 class="m-0 font-weight-bold">Galaxy AI 3.1</h5>
                    <small class="text-success"><i class="fas fa-circle" style="font-size: 8px;"></i> Online</small>
                </div>
            </div>
            <button class="btn btn-sm btn-light border-circle"><i class="fas fa-ellipsis-v"></i></button>
        </div>

        <div id="chatBox" class="chat-body custom-scroll">
            <div class="msg bot-msg">
                Hello ! I'm your  assistant for manage employing pannel. Ready to manage your bus fleet?
            </div>
        </div>

        <div class="chat-footer">
            <div class="input-container">
                <input type="text" id="userInput" placeholder="Ask anything about bus reservation..." autocomplete="off">
                <button class="send-btn" onclick="sendToAI()">
                    <i class="fas fa-arrow-up"></i>
                </button>
            </div>
            <div class="footer-tag">Galaxy Software House © 2026</div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    /* Full Page Settings - No Scroll */
    .chat-wrapper {
        height: 85vh; /* Screen ke andar fit rahega */
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #f7f7f8; /* Very light gray background */
        padding: 20px;
        overflow: hidden;
    }

    .chat-card {
        width: 100%;
        max-width: 800px;
        height: 100%;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        display: flex;
        flex-direction: column;
        border: 1px solid #e5e5e5;
    }

    /* Header */
    .chat-header {
        padding: 16px 24px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .bot-icon {
        width: 35px;
        height: 35px;
        background: #000;
        color: #fff;
        border-radius: 8px;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-right: 12px;
    }

    /* Chat Body */
    .chat-body {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        background-color: #ffffff;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .msg {
        max-width: 85%;
        padding: 12px 16px;
        font-size: 15px;
        line-height: 1.5;
        border-radius: 12px;
    }

    .bot-msg {
        background-color: #f1f1f1;
        color: #222;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
    }

    .user-msg {
        background-color: #000000;
        color: #ffffff;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }

    /* Input Area */
    .chat-footer {
        padding: 20px 24px;
        background: #ffffff;
    }

    .input-container {
        position: relative;
        display: flex;
        align-items: center;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        padding: 8px 12px;
        transition: 0.2s;
    }

        .input-container:focus-within {
            border-color: #000;
            box-shadow: 0 0 0 2px rgba(0,0,0,0.05);
        }

        .input-container input {
            flex: 1;
            border: none;
            outline: none;
            padding: 8px;
            font-size: 15px;
        }

    .send-btn {
        background: #000;
        color: #fff;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }

        .send-btn:hover {
            background: #333;
        }

    .footer-tag {
        text-align: center;
        font-size: 11px;
        color: #999;
        margin-top: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Slim Scrollbar */
    .custom-scroll::-webkit-scrollbar {
        width: 5px;
    }

    .custom-scroll::-webkit-scrollbar-thumb {
        background: #eee;
        border-radius: 10px;
    }
</style>

<script>
    async function sendToAI() {
        const input = document.getElementById("userInput");
        const chatBox = document.getElementById("chatBox");
        const message = input.value.trim();
        if (!message) return;

        chatBox.innerHTML += `<div class="msg user-msg">${message}</div>`;
        input.value = "";
        chatBox.scrollTop = chatBox.scrollHeight;

        const typingId = "typing-" + Date.now();
        chatBox.innerHTML += `<div id="${typingId}" class="msg bot-msg">Thinking...</div>`;
        chatBox.scrollTop = chatBox.scrollHeight;

        try {
            const response = await fetch('/ChatBot/GetResponse', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `userMessage=${encodeURIComponent(message)}`
            });
            const data = await response.json();
            document.getElementById(typingId).remove();
            chatBox.innerHTML += `<div class="msg bot-msg">${data.reply}</div>`;
        } catch (error) {
            document.getElementById(typingId).innerHTML = "System error. Check connection.";
        }
        chatBox.scrollTop = chatBox.scrollHeight;
    }

    document.getElementById("userInput").addEventListener("keypress", (e) => {
        if (e.key === "Enter") sendToAI();
    });
</script>