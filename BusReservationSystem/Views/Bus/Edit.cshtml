@model BusReservationSystem.Models.Bus

@{
    ViewData["Title"] = "Update Bus Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-wrapper {
        background: #f8fafc;
        padding: 40px 0;
        min-height: 100vh;
    }

    .form-container {
        max-width: 900px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
    }

    .form-header {
        border-bottom: 2px solid #f1f5f9;
        margin-bottom: 30px;
        padding-bottom: 15px;
    }

        .form-header h2 {
            color: #1e293b;
            font-weight: 800;
            font-size: 24px;
        }

    .info-strip {
        background: #f1f5f9;
        padding: 10px 15px;
        border-radius: 8px;
        margin-bottom: 25px;
        font-size: 13px;
        color: #475569;
        font-weight: 600;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 25px;
    }

    .form-group label {
        font-weight: 700;
        margin-bottom: 8px;
        font-size: 13px;
        text-transform: uppercase;
        color: #475569;
    }

    .form-control-custom {
        padding: 12px 16px;
        border-radius: 8px;
        border: 1.5px solid #e2e8f0;
        font-size: 15px;
        width: 100%;
        transition: all 0.3s ease;
    }

        .form-control-custom:focus {
            border-color: #764ba2;
            outline: none;
            box-shadow: 0 0 0 4px rgba(118, 75, 162, 0.1);
        }

    .full-width {
        grid-column: span 2;
    }

    .btn-group-custom {
        margin-top: 40px;
        padding-top: 20px;
        border-top: 2px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 15px;
    }

    .btn-update {
        background: #3b82f6;
        color: white;
        padding: 12px 35px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-back {
        text-decoration: none;
        padding: 12px 25px;
        border-radius: 8px;
        background: #f1f5f9;
        color: #475569;
        font-weight: 600;
    }
</style>

<div class="form-wrapper">
    <div class="form-container">
        <div class="form-header">
            <h2>Edit Bus Details</h2>
            <p>Modify the information for the selected vehicle.</p>
        </div>

        <div class="info-strip">
            BUS CODE: @Model.BusCode | REGISTRATION: @Model.BusNumber
        </div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="BusId" />
            <input type="hidden" asp-for="BusCode" />
            <input type="hidden" asp-for="BusNumber" />

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="BusType">Vehicle Category</label>
                    <select asp-for="BusType" class="form-control-custom">
                        <option>AC Standard</option>
                        <option>Non-AC Economy</option>
                        <option>Executive Luxury</option>
                        <option>Sleeper Class</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Status">Operational Status</label>
                    <select asp-for="Status" class="form-control-custom">
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                        <option value="Maintenance">Under Maintenance</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="StartingPoint">Departure City</label>
                    <input asp-for="StartingPoint" class="form-control-custom" />
                </div>

                <div class="form-group">
                    <label asp-for="DestinationPoint">Arrival City</label>
                    <input asp-for="DestinationPoint" class="form-control-custom" />
                </div>

                <div class="form-group">
                    <label asp-for="DepartureTime">Departure Time</label>
                    <input asp-for="DepartureTime" type="time" class="form-control-custom" />
                </div>

                <div class="form-group">
                    <label asp-for="ArrivalTime">Arrival Time</label>
                    <input asp-for="ArrivalTime" type="time" class="form-control-custom" />
                </div>

                <div class="form-group full-width">
                    <label asp-for="TotalSeats">Seats (Careful: Changing this won't auto-update seat records)</label>
                    <input asp-for="TotalSeats" type="number" class="form-control-custom" readonly />
                    <small class="text-muted">Seating capacity is fixed after registration.</small>
                </div>
            </div>

            <div class="btn-group-custom">
                <a asp-action="ViewBus" class="btn-back">Cancel Changes</a>
                <button type="submit" class="btn-update">Update Bus</button>
            </div>
        </form>
    </div>
</div>