@model BusReservationSystem.Models.Bus

@{
    ViewData["Title"] = "Bus Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .details-container {
        max-width: 1000px;
        margin: 30px auto;
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .details-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

        .details-header h2 {
            color: #2c3e50;
        }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .detail-box {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
    }

        .detail-box h4 {
            font-size: 13px;
            color: #7f8c8d;
            margin-bottom: 5px;
        }

        .detail-box p {
            font-size: 15px;
            font-weight: 600;
            color: #2c3e50;
            margin: 0;
        }

    .status-active {
        color: green;
        font-weight: 600;
    }

    .status-inactive {
        color: red;
        font-weight: 600;
    }

    .btn-group {
        margin-top: 30px;
        display: flex;
        justify-content: space-between;
    }

    .edit-btn {
        background: #3498db;
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        transition: 0.3s;
    }

        .edit-btn:hover {
            background: #2980b9;
        }

    .back-btn {
        background: #7f8c8d;
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        transition: 0.3s;
    }

        .back-btn:hover {
            background: #636e72;
        }

    @@media (max-width: 768px) {
        .details-grid

    {
        grid-template-columns: 1fr;
    }

    }
</style>

<div class="details-container">

    <div class="details-header">
        <h2>Bus Details</h2>
    </div>

    <div class="details-grid">

        <div class="detail-box">
            <h4>Bus Code</h4>
            <p>@Model.BusCode</p>
        </div>

        <div class="detail-box">
            <h4>Bus Number</h4>
            <p>@Model.BusNumber</p>
        </div>

        <div class="detail-box">
            <h4>Bus Type</h4>
            <p>@Model.BusType</p>
        </div>

        <div class="detail-box">
            <h4>Total Seats</h4>
            <p>@Model.TotalSeats</p>
        </div>

        <div class="detail-box">
            <h4>Route</h4>
            <p>@Model.StartingPoint → @Model.DestinationPoint</p>
        </div>

        <div class="detail-box">
            <h4>Distance</h4>
            <p>@Model.DistanceInKm KM</p>
        </div>

        <div class="detail-box">
            <h4>Departure Time</h4>
            <p>@Model.DepartureTime</p>
        </div>

        <div class="detail-box">
            <h4>Arrival Time</h4>
            <p>@Model.ArrivalTime</p>
        </div>

        <div class="detail-box">
            <h4>Status</h4>
            @if (Model.Status == "Active")
            {
                <p class="status-active">Active</p>
            }
            else
            {
                <p class="status-inactive">Inactive</p>
            }
        </div>

        <div class="detail-box" style="grid-column: span 2;">
            <h4>Route Description</h4>
            <p>@Model.RouteDescription</p>
        </div>

    </div>

    <div class="btn-group">
        <a asp-action="ViewBus" class="back-btn">Back to List</a>
        <a asp-action="Edit" asp-route-id="@Model.BusId" class="edit-btn">Edit Bus</a>
    </div>

</div>