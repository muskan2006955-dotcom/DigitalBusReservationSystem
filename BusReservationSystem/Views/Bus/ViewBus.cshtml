@model IEnumerable<BusReservationSystem.Models.Bus>

@{
    ViewData["Title"] = "Fleet Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .glass-card {
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
    }

    .search-section {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 20px;
        border-radius: 12px 12px 0 0;
    }

    .table thead th {
        background-color: #ffffff;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        padding: 15px;
        border-bottom: 2px solid #f1f5f9;
        text-align: left;
    }

    .bus-info {
        display: flex;
        flex-direction: column;
    }

    .bus-code {
        font-size: 10px;
        color: #94a3b8;
        font-weight: 700;
    }

    .route-badge {
        background: #eff6ff;
        color: #1e40af;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: white !important;
        transition: 0.2s;
        border: none;
    }

    .btn-edit {
        background: #3b82f6;
    }

    .btn-details {
        background: #8b5cf6;
    }

    .btn-delete {
        background: #ef4444;
    }

    .action-btn:hover {
        transform: scale(1.1);
        opacity: 0.9;
    }

    .status-active {
        background: #dcfce7;
        color: #15803d;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
    }

    .status-inactive {
        background: #fee2e2;
        color: #b91c1c;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Fleet Management</h3>
            <p class="text-muted mb-0">Monitor and manage your bus routes and vehicles</p>
        </div>
        <a asp-action="Create" class="btn btn-success px-4 py-2 shadow-sm" style="border-radius: 8px;">
            <i class="fa fa-plus me-2"></i>Add New Bus
        </a>
    </div>

    <div class="glass-card">
        <div class="search-section">
            <form method="get" asp-action="ViewBus" class="row g-2">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="fa fa-bus"></i>
                        </span>
                        <input type="text" name="searchTerm" class="form-control border-start-0 shadow-none"
                               placeholder="Search by Bus Number, Code, or City..."
                               value="@Context.Request.Query["searchTerm"]">
                    </div>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-grow-1">Search</button>
                    <a asp-action="ViewBus" class="btn btn-outline-secondary px-3">
                        <i class="fa fa-sync-alt"></i>
                    </a>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Bus Identifiers</th>
                        <th>Type & Seats</th>
                        <th>Route Details</th>
                        <th>Departure</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa fa-search d-block mb-2 fs-3"></i>
                                No buses found in the fleet.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="bus-info">
                                    <span class="bus-code">@item.BusCode</span>
                                    <span class="fw-bold text-dark">@item.BusNumber</span>
                                </div>
                            </td>
                            <td>
                                <div class="small fw-medium">@item.BusType</div>
                                <div class="text-muted" style="font-size: 11px;">Total Seats: @item.TotalSeats</div>
                            </td>
                            <td>
                                <div class="route-badge">
                                    @item.StartingPoint <i class="fa fa-long-arrow-alt-right mx-1"></i> @item.DestinationPoint
                                </div>
                            </td>
                            <td class="small">
                                <i class="fa fa-clock text-muted me-1"></i> @item.DepartureTime
                            </td>
                            <td>
                                <span class="@(item.Status == "Active" ? "status-active" : "status-inactive")">
                                    @item.Status
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.BusId"
                                       class="btn btn-sm btn-primary px-3" style="font-size: 11px; font-weight: 600;">
                                        Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.BusId"
                                       class="btn btn-sm btn-info text-white px-3" style="font-size: 11px; font-weight: 600; background-color: #8b5cf6; border: none;">
                                        View
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.BusId"
                                       onclick="return confirm('Deleting this bus will also remove all its seats. Proceed?')"
                                       class="btn btn-sm btn-danger px-3" style="font-size: 11px; font-weight: 600;">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>