@model IEnumerable<BusReservationSystem.Models.Booking>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: white;
            font-family: 'Segoe UI', sans-serif;
        }

        .print-btn {
            background: #198754;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
        }

        @@media print {
            .no-print {
                display: none;
            }
        }

        .table-custom th {
            background-color: #f8f9fa;
        }
    </style>
</head>
<body class="p-5">

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h1 class="fw-bold text-primary">BUS RESERVE</h1>
            <p class="text-muted">Sales Performance Report</p>
        </div>
        <div class="text-end">
            <button onclick="window.print()" class="print-btn no-print border-0">Print to PDF</button>
            <p class="mt-2 mb-0 fw-bold">Period: @ViewBag.FromDate To @ViewBag.ToDate</p>
        </div>
    </div>

    <div class="row mb-4 text-center">
        <div class="col-md-4">
            <div class="border py-3">
                <p class="text-muted mb-0 small">Total Bookings</p>
                <h3 class="fw-bold">@ViewBag.TotalBookings</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border py-3">
                <p class="text-muted mb-0 small">Total Earnings</p>
                <h3 class="fw-bold text-success">Rs. @ViewBag.TotalEarnings.ToString("N2")</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border py-3">
                <p class="text-muted mb-0 small">Cancelled Bookings</p>
                <h3 class="fw-bold text-danger">@ViewBag.CancelledCount</h3>
            </div>
        </div>
    </div>

    <table class="table table-bordered table-custom">
        <thead>
            <tr>
                <th>Date</th>
                <th>Customer</th>
                <th>Bus Info</th>
                <th>Seat</th>
                <th class="text-end">Amount</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.BookingDate?.ToString("dd/MM/yyyy")</td>
                    <td>@b.Customer?.CustomerName</td>
                    <td>@b.Bus?.BusNumber</td>
                    <td>@b.SeatNumber</td>
                    <td class="text-end fw-bold">@b.FinalAmount</td>
                    <td><span class="badge @(b.BookingStatus == "Cancelled" ? "bg-danger" : "bg-success") text-dark">@b.BookingStatus</span></td>
                </tr>
            }
        </tbody>
    </table>

    <p class="text-center mt-5 text-muted small">Generated on: @DateTime.Now.ToString("f")</p>

</body>
</html>