@{
    ViewData["Title"] = "Sales Reports";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header text-white py-3" style="background-color:#005555">
                    <h5 class="mb-0"><i class="fas fa-file-invoice-dollar me-2"></i>Generate Sales Report</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="GenerateReport" method="get" target="_blank">
                        <div class="mb-3">
                            <label class="form-label fw-bold">From Date</label>
                            <input type="date" name="fromDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">To Date</label>
                            <input type="date" name="toDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <button type="submit" class="btn  w-100 py-2 rounded-pill shadow-sm" style="background-color:#005555">
                            <i class="fas fa-search me-2"></i> View & Print Report
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>