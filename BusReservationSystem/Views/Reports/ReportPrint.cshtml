@model IEnumerable<BusReservationSystem.Models.Booking>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Sales Report - @ViewBag.EmpID</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: white;
            font-family: 'Segoe UI', sans-serif;
        }

        .print-header {
            border-bottom: 3px solid #0d6efd;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .table thead {
            background-color: #f8f9fa;
            border-top: 2px solid #dee2e6;
        }

        .summary-box {
            border: 2px solid #0d6efd;
            padding: 15px;
            border-radius: 10px;
            background-color: #f0f7ff;
        }

        @@media print {
            .no-print {
                display: none;
            }
        }
    </style>
</head>
<body class="p-5">

    <div class="print-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="text-primary fw-bold mb-0">BUS RESERVE</h1>
            <p class="text-muted">Personal Sales Performance Report</p>
        </div>
        <div class="text-end">
            <button onclick="window.print()" class="btn btn-dark no-print mb-2">Print to PDF</button>
            <h5 class="fw-bold">Report Period</h5>
            <span class="text-primary">@ViewBag.From — @ViewBag.To</span>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-4">
            <div class="summary-box text-center">
                <small class="text-muted text-uppercase fw-bold">Total Sales</small>
                <h2 class="fw-bold text-primary mb-0">Rs. @ViewBag.TotalAmount.ToString("N2")</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 text-center border rounded">
                <small class="text-muted text-uppercase fw-bold">Bookings Count</small>
                <h2 class="fw-bold mb-0">@Model.Count()</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 text-center border rounded">
                <small class="text-muted text-uppercase fw-bold">Employee ID</small>
                <h2 class="fw-bold mb-0">@ViewBag.EmpID</h2>
            </div>
        </div>
    </div>

    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Booking Date</th>
                <th>ID</th>
                <th>Customer</th>
                <th>Bus Info</th>
                <th class="text-center">Seat</th>
                <th class="text-end">Fare</th>
                <th class="text-center">Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.BookingDate?.ToString("dd/MM/yyyy")</td>
                    <td class="fw-bold">#@item.BookingId</td>
                    <td>@item.Customer?.CustomerName</td>
                    <td>@item.Bus?.BusNumber (@item.Bus?.BusType)</td>
                    <td class="text-center"><span class="badge bg-light text-dark border">@item.SeatNumber</span></td>
                    <td class="text-end fw-bold text-success">@item.FinalAmount?.ToString("N2")</td>
                    <td class="text-center">
                        <span class="badge @(item.BookingStatus == "Cancelled" ? "bg-danger" : "bg-success")">
                            @item.BookingStatus
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-5 pt-5 text-center text-muted border-top">
        <p>This report is confidential and system-generated on @DateTime.Now.ToString("f")</p>
    </div>

</body>
</html>