@model IEnumerable<BusReservationSystem.Models.PriceList>

@{
    ViewData["Title"] = "Manage Prices";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .glass-card {
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
    }

    .search-section {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 20px;
        border-radius: 12px 12px 0 0;
    }

    .table thead th {
        background-color: #ffffff;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        padding: 15px;
        border-bottom: 2px solid #f1f5f9;
    }

    .price-tag {
        font-weight: 700;
        color: #0f172a;
        font-size: 15px;
    }

    .tax-badge {
        background: #fef3c7;
        color: #92400e;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
    }

    .bus-type-text {
        font-weight: 600;
        color: #3b82f6;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Pricing & Tariffs</h3>
            <p class="text-muted mb-0">Configure ticket rates based on bus categories</p>
        </div>
    </div>

    <div class="glass-card">
        <div class="search-section">
            <form method="get" asp-action="Index" class="row g-2">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="fa fa-filter"></i>
                        </span>
                        <input type="text" name="searchTerm" class="form-control border-start-0 shadow-none"
                               placeholder="Search by Bus Type (AC, Luxury, etc.)..."
                               value="@Context.Request.Query["searchTerm"]">
                    </div>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-grow-1">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Reset</a>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Bus Category</th>
                        <th>Rate (Per KM)</th>
                        <th>Tax Rate</th>
                        <th>Effective Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="bus-type-text">@item.BusType</span>
                                </td>
                                <td>
                                    <span class="price-tag">@item.PricePerKm?.ToString("C")</span>
                                </td>
                                <td>
                                    <span class="tax-badge">@item.TaxPercentage%</span>
                                </td>
                                <td>
                                    <div class="small text-muted">
                                        <i class="fa fa-calendar-alt me-1"></i>
                                        @item.EffectiveDate?.ToString("dd MMM yyyy")
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.PriceId"
                                           class="btn btn-sm btn-primary px-3" style="font-size: 11px; font-weight: 600;">
                                            Edit
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.PriceId"
                                           class="btn btn-sm btn-light px-3" style="font-size: 11px; font-weight: 600; border: 1px solid #e2e8f0;">
                                            View
                                        </a>
                                        @* <a asp-action="Delete" asp-route-id="@item.PriceId"
                                           onclick="return confirm('Are you sure you want to remove this price record?')"
                                           class="btn btn-sm btn-danger px-3" style="font-size: 11px; font-weight: 600;">
                                            Delete
                                        </a> *@
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa fa-receipt d-block mb-2 fs-3"></i>
                                No pricing records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>