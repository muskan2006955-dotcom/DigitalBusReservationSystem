@model BusReservationSystem.Models.PriceList

@{
    ViewData["Title"] = "Price Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .details-wrapper {
        background: #f8fafc;
        padding: 40px 0;
        min-height: 80vh;
    }

    .details-container {
        max-width: 700px;
        margin: 0 auto;
        background: white;
        padding: 0;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
        overflow: hidden;
    }

    .details-header {
        background: #1e293b;
        color: white;
        padding: 30px;
        text-align: center;
    }

        .details-header h2 {
            margin: 0;
            font-weight: 700;
            font-size: 22px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .details-body {
        padding: 40px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
        margin-bottom: 30px;
    }

    .info-item {
        display: flex;
        flex-direction: column;
    }

    .info-label {
        font-size: 11px;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        margin-bottom: 8px;
        letter-spacing: 0.5px;
    }

    .info-value {
        font-size: 18px;
        font-weight: 600;
        color: #1e293b;
    }

    .price-highlight {
        color: #10b981;
        font-size: 24px;
    }

    .footer-actions {
        background: #f8fafc;
        padding: 20px 40px;
        display: flex;
        justify-content: space-between;
        border-top: 1px solid #f1f5f9;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        font-size: 14px;
        transition: 0.3s;
    }

    .btn-edit-main {
        background: #3b82f6;
        color: white;
    }

        .btn-edit-main:hover {
            background: #2563eb;
            transform: translateY(-2px);
        }

    .btn-back-main {
        background: #e2e8f0;
        color: #475569;
    }

        .btn-back-main:hover {
            background: #cbd5e1;
        }
</style>

<div class="details-wrapper">
    <div class="details-container">
        <div class="details-header">
            <h2>@Model.BusType Pricing Details</h2>
        </div>

        <div class="details-body">
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Bus Category</span>
                    <span class="info-value">@Model.BusType</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Effective From</span>
                    <span class="info-value">@Model.EffectiveDate?.ToString("dd MMMM, yyyy")</span>
                </div>
            </div>

            <hr style="border: 0; border-top: 1px solid #f1f5f9; margin: 20px 0;">

            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Base Rate (Per KM)</span>
                    <span class="info-value price-highlight">@Model.PricePerKm?.ToString("C")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Tax Applied</span>
                    <span class="info-value" style="color: #f59e0b;">@Model.TaxPercentage%</span>
                </div>
            </div>

            <div class="mt-4 p-3 rounded" style="background: #eff6ff; border-left: 4px solid #3b82f6;">
                <p class="mb-0 small text-muted">
                    <strong>Note:</strong> This pricing applies to all routes for <strong>@Model.BusType</strong> buses.
                    Any updates to this rate will immediately reflect in new booking calculations.
                </p>
            </div>
        </div>

        <div class="footer-actions">
            <a asp-action="Index" class="btn-custom btn-back-main">Back to List</a>
            <a asp-action="Edit" asp-route-id="@Model.PriceId" class="btn-custom btn-edit-main">Modify Pricing</a>
        </div>
    </div>
</div>