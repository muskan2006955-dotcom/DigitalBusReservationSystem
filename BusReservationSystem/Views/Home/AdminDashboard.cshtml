@model BusReservationSystem.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    /* 2. Global Fixes for Sidebar Layout */
    .admin-wrapper {
        background-color: #f4f7f6;
        padding: 25px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* 3. Cards Styling - Making them look Professional */
    .card-stat {
        border: none;
        border-radius: 12px;
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        color: white;
        position: relative;
        overflow: hidden;
        min-height: 110px;
        display: flex;
        align-items: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

        .card-stat:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        }

    /* Gradient Backgrounds */
    .gradient-revenue {
        background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%);
    }

    .gradient-buses {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
    }

    .gradient-agents {
        background: linear-gradient(135deg, #f6c23e 0%, #dda20a 100%);
    }

    .gradient-cancel {
        background: linear-gradient(135deg, #e74a3b 0%, #be2617 100%);
    }

    .card-stat i {
        position: absolute;
        right: 15px;
        bottom: 15px;
        font-size: 3rem;
        opacity: 0.2;
    }

    /* 4. Table Customization */
    .table-container {
        background: white;
        border-radius: 15px;
        border: none;
        padding: 20px;
        margin-top: 30px;
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1);
    }

    .table thead th {
        background-color: #f8fafc;
        color: #4e73df;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 1px;
        border: none;
        padding: 15px;
    }

    .status-pill {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
    }
</style>

<div class="admin-wrapper">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold text-dark m-0">Galaxy Executive Dashboard 🚀</h2>
            <p class="text-muted">Welcome back, <strong>@Model.AdminName</strong>. Here's what's happening today.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <div class="d-inline-block bg-white shadow-sm p-3 rounded-4 border">
                <i class="fa fa-clock text-primary me-2"></i>
                <span class="fw-bold">@DateTime.Now.ToString("HH:mm tt")</span>
                <span class="mx-2 text-muted">|</span>
                <span class="text-muted">@DateTime.Now.ToString("dd MMM")</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-3 col-lg-6">
            <div class="card card-stat gradient-revenue">
                <div class="card-body">
                    <div class="small fw-bold opacity-75">TOTAL REVENUE</div>
                    <div class="h3 fw-bold mb-0">Rs. @Model.TotalRevenue.ToString("N0")</div>
                    <i class="fa fa-sack-dollar"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="card card-stat gradient-buses">
                <div class="card-body">
                    <div class="small fw-bold opacity-75">ACTIVE FLEET</div>
                    <div class="h3 fw-bold mb-0">@Model.TotalBuses</div>
                    <i class="fa fa-bus"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="card card-stat gradient-agents">
                <div class="card-body">
                    <div class="small fw-bold opacity-75">TOTAL AGENTS</div>
                    <div class="h3 fw-bold mb-0">@Model.ActiveAgents</div>
                    <i class="fa fa-user-tie"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="card card-stat gradient-cancel">
                <div class="card-body">
                    <div class="small fw-bold opacity-75">CANCELLATIONS</div>
                    <div class="h3 fw-bold mb-0">@Model.TotalCancellations</div>
                    <i class="fa fa-ticket-simple"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="table-container">
        <div class="d-flex justify-content-between align-items-center mb-4 ps-2">
            <h5 class="fw-bold text-dark m-0"><i class="fa fa-list-ul me-2 text-primary"></i>Recent System Bookings</h5>
            <button class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold">View Full Report</button>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Passenger</th>
                        <th>Route / Bus</th>
                        <th>Booking Agent</th>
                        <th>Amount</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentSystemBookings != null && Model.RecentSystemBookings.Any())
                    {
                        foreach (var b in Model.RecentSystemBookings)
                        {
                            <tr>
                                <td class="ps-3 text-muted fw-bold">#@b.BookingId</td>
                                <td>
                                    <div class="fw-bold">@b.Customer?.CustomerName</div>
                                    <div class="text-muted" style="font-size: 11px;">@b.Customer?.PhoneNumber</div>
                                </td>
                                <td>
                                    <div class="fw-bold">@b.Bus?.BusNumber</div>
                                    <div class="text-muted" style="font-size: 11px;">@b.StartingPoint ➔ @b.DestinationPoint</div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark fw-normal border">
                                        <i class="fa fa-user-circle text-primary me-1"></i> @(b.BookedByNavigation?.FirstName ?? "Admin")
                                    </span>
                                </td>
                                <td class="fw-bold text-success">Rs. @b.FinalAmount?.ToString("N0")</td>
                                <td class="text-center">
                                    @if (b.BookingStatus == "Cancelled")
                                    {
                                        <span class="status-pill bg-danger-subtle text-danger border border-danger">Cancelled</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill bg-success-subtle text-success border border-success">Confirmed</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="fa fa-folder-open fa-3x text-light mb-3"></i><br />
                                <span class="text-muted">No system bookings found for today.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>