@model BusReservationSystem.Models.Customer

@{
    ViewData["Title"] = "Add New Customer";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml"; // Aapka layout path
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header  text-white p-3" style="background-color:#005555">
            <h4 class="mb-0"><i class="fa fa-user-plus"></i> Register New Customer</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 border-end">
                        <h5 class="text-info mb-3"><i class="fa fa-info-circle"></i> Personal Details</h5>

                        <div class="form-group mb-3">
                            <label asp-for="CustomerName" class="form-label font-weight-bold">Full Name</label>
                            <input asp-for="CustomerName" class="form-control" placeholder="Enter customer name" required />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Age" class="form-label font-weight-bold">Age</label>
                                    <input asp-for="Age" type="number" class="form-control" min="1" max="110" required />
                                    <span asp-validation-for="Age" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Gender" class="form-label font-weight-bold">Gender</label>
                                    <select asp-for="Gender" class="form-control" required>
                                        <option value="">-- Select --</option>
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="text-info mb-3"><i class="fa fa-id-card"></i> Contact & Verification</h5>

                        <div class="form-group mb-3">
                            <label asp-for="PhoneNumber" class="form-label font-weight-bold">Mobile Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="e.g. 0300-1234567" required />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="IdproofNumber" class="form-label font-weight-bold">CNIC / ID Proof Number</label>
                            <input asp-for="IdproofNumber" class="form-control" placeholder="13-digit ID Number" required />
                            <span asp-validation-for="IdproofNumber" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="form-group text-center">
                    <button type="submit" class="btn  btn-lg px-5 shadow-sm" style="background-color:#005555; color:white">
                        <i class="fa fa-save"></i> Save Customer
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 ms-2">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}