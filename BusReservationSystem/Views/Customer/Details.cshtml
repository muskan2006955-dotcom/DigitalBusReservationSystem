@model BusReservationSystem.Models.Customer

@{
    ViewData["Title"] = "Customer Profile";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center p-4 mb-4">
                <div class="mb-3">
                    <i class="fa fa-user-circle fa-5x text-primary"></i>
                </div>
                <h4 class="fw-bold">@Model.CustomerName</h4>
                <p class="text-muted small">Customer ID: #@Model.CustomerId</p>
                <hr />
                <div class="text-start">
                    <p><strong><i class="fa fa-phone text-primary me-2"></i> Phone:</strong> @Model.PhoneNumber</p>
                    <p><strong><i class="fa fa-id-badge text-primary me-2"></i> CNIC:</strong> @Model.IdproofNumber</p>
                    <p><strong><i class="fa fa-venus-mars text-primary me-2"></i> Gender:</strong> @Model.Gender</p>
                    <p><strong><i class="fa fa-birthday-cake text-primary me-2"></i> Age:</strong> @Model.Age Years</p>
                </div>
                <div class="mt-3 d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-warning">
                        <i class="fa fa-edit"></i> Edit Profile
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 text-primary fw-bold"><i class="fa fa-history"></i> Travel History</h5>
                </div>
                <div class="card-body">
                    @if (Model.Bookings != null && Model.Bookings.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Route</th>
                                        <th>Bus</th>
                                        <th>Seat</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var booking in Model.Bookings.OrderByDescending(b => b.TravelDate))
                                    {
                                        <tr>
                                            <td>@booking.TravelDate.ToString("dd MMM yyyy")</td>
                                            <td>@booking.StartingPoint <i class="fa fa-arrow-right small"></i> @booking.DestinationPoint</td>
                                            <td>@booking.Bus?.BusNumber</td>
                                            <td><span class="badge bg-info">@booking.SeatNumber</span></td>
                                            <td>
                                                <span class="badge @(booking.BookingStatus == "Booked" ? "bg-success" : "bg-danger")">
                                                    @booking.BookingStatus
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fa fa-folder-open fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No travel history found for this customer.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>