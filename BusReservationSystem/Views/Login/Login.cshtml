@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Bus Reservation System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            overflow: hidden;
            background-color: #f3f4f6;
        }

        .login-wrapper {
            display: flex;
            height: 100vh;
            width: 100%;
            position: relative;
        }

        /* Back to Website Button */
        .back-to-site {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(5px);
            color: white;
            padding: 8px 15px;
            border-radius: 50px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            border: 1px solid rgba(255, 255, 255, 0.3);
            transition: 0.3s;
        }

            .back-to-site:hover {
                background: white;
                color: #111827;
            }

        /* Left Side - Image Section */
        .login-left {
            flex: 1.2;
            /* OFFLINE TIP: images folder mein login-bus.jpg ke naam se pic save karein */
            background:  url('~/img/bus.png');
            /* Agar image nahi mili toh ye backup color dikhayega */
            background-color: #005555;
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 40px;
            text-align: center;
        }

            .login-left h1 {
                font-size: 3.5rem;
                font-weight: 800;
                margin-bottom: 15px;
            }

            .login-left p {
                font-size: 1.2rem;
                max-width: 450px;
                opacity: 0.9;
            }

        /* Right Side - Form Section */
        .login-right {
            flex: 0.8;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0 80px;
            min-width: 450px;
        }

        .form-container {
            width: 100%;
            max-width: 380px;
            margin: 0 auto;
        }

        h2 {
            font-weight: 700;
            color: #111827;
            margin-bottom: 8px;
        }

        .subtitle {
            color: #6b7280;
            margin-bottom: 35px;
            font-size: 15px;
        }

        .input-group-custom {
            margin-bottom: 20px;
        }

            .input-group-custom label {
                display: block;
                font-weight: 600;
                font-size: 13px;
                color: #374151;
                margin-bottom: 8px;
            }

            .input-group-custom input {
                width: 100%;
                padding: 12px 15px;
                border: 1px solid #d1d5db;
                border-radius: 8px;
                font-size: 15px;
                background: #f9fafb;
                transition: 0.2s;
            }

                .input-group-custom input:focus {
                    outline: none;
                    border-color: #3b82f6;
                    background: white;
                    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
                }

        .login-btn {
            width: 100%;
            padding: 14px;
            background: #111827;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 16px;
            transition: 0.3s;
            margin-top: 10px;
        }

            .login-btn:hover {
                background: #1f2937;
                transform: translateY(-1px);
            }

        .error-msg {
            margin-top: 20px;
            padding: 10px;
            background: #fef2f2;
            color: #dc2626;
            border-radius: 8px;
            font-size: 13px;
            text-align: center;
            border: 1px solid #fee2e2;
        }

        @@media (max-width: 992px) {
            .login-left {
                display: none;
            }

            .login-right {
                flex: 1;
                padding: 40px;
            }

            .back-to-site {
                color: #111827;
                border-color: #d1d5db;
                background: white;
            }
        }
    </style>
</head>
<body>

    <div class="login-wrapper">
        <a asp-controller="Home" asp-action="Index" class="back-to-site">
            <i class="fa fa-arrow-left me-2"></i> Back to Website
        </a>

        <div class="login-left">
            <h1>Travel Swift</h1>
            <p>Reliable, comfortable, and efficient bus management for modern travelers.</p>
        </div>

        <div class="login-right">
            <div class="form-container">
                <h2>Staff Login</h2>
                <p class="subtitle">Welcome back! Please enter your details.</p>

                <form asp-action="Login" method="post">
                    <div class="input-group-custom">
                        <label>Username</label>
                        <input type="text" name="username" placeholder="Enter username" required>
                    </div>

                    <div class="input-group-custom">
                        <label>Password</label>
                        <input type="password" name="password" placeholder="••••••••" required>
                    </div>

                    <button type="submit" class="login-btn">
                        Sign In
                    </button>

                    @if (ViewBag.Error != null)
                    {
                        <div class="error-msg">
                            <i class="fa fa-exclamation-circle me-1"></i> @ViewBag.Error
                        </div>
                    }
                </form>

                <div class="mt-5 text-center text-muted" style="font-size: 12px;">
                    &copy; @DateTime.Now.Year Bus Reservation System
                </div>
            </div>
        </div>
    </div>

</body>
</html>