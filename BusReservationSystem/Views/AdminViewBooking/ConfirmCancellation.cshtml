@model BusReservationSystem.Models.Booking

@{
    ViewData["Title"] = "Confirm Cancellation";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header bg-white border-bottom py-3">
                    <h4 class="mb-0 text-danger fw-bold text-center">
                        <i class="fas fa-exclamation-triangle me-2"></i>Confirm Ticket Cancellation
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="bg-light p-3 rounded mb-4 border-start border-4 border-primary">
                        <div class="row">
                            <div class="col-6">
                                <small class="text-muted d-block">Customer Name</small>
                                <span class="fw-bold">@Model.Customer?.CustomerName</span>
                            </div>
                            <div class="col-6 text-end">
                                <small class="text-muted d-block">Booking ID</small>
                                <span class="fw-bold text-primary">#@Model.BookingId</span>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-6">
                                <small class="text-muted d-block">Bus / Route</small>
                                <span class="fw-bold">@Model.Bus?.BusType</span>
                            </div>
                            <div class="col-6 text-end">
                                <small class="text-muted d-block">Seat Number</small>
                                <span class="badge bg-dark">@Model.SeatNumber</span>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-3">Refund Calculation:</h6>
                    <div class="table-responsive mb-4">
                        <table class="table table-bordered align-middle">
                            <tr class="table-secondary">
                                <td>Original Paid Amount:</td>
                                <td class="text-end fw-bold">@Model.FinalAmount?.ToString("N2")</td>
                            </tr>
                            <tr class="text-danger">
                                <td>
                                    Cancellation Deduction (@ViewBag.Percentage%):
                                    <br /><small class="text-muted">(Based on @ViewBag.PolicyDays days policy)</small>
                                </td>
                                <td class="text-end fw-bold">- @ViewBag.Deduction.ToString("N2")</td>
                            </tr>
                            <tr class="table-success" style="font-size: 1.2rem;">
                                <td class="fw-bold">Net Refundable Amount:</td>
                                <td class="text-end fw-bold text-success">@ViewBag.Refund.ToString("N2")</td>
                            </tr>
                        </table>
                    </div>

                    <div class="alert alert-info small py-2">
                        <i class="fas fa-info-circle me-1"></i>
                        Confirming this will mark the seat as <strong>Available</strong> and update the booking status.
                    </div>

                    <form asp-action="Cancel" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.BookingId" />

                        <div class="row g-2 mt-2">
                            <div class="col-md-8">
                                <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold">
                                    <i class="fas fa-check-circle me-1"></i> Proceed with Cancellation
                                </button>
                            </div>
                            <div class="col-md-4">
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100">
                                    Keep Booking
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>