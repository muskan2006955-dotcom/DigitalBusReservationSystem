@model IEnumerable<BusReservationSystem.Models.Booking>

@{
    ViewData["Title"] = "Admin - All Bookings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .glass-card {
        border-radius: 12px;
        border: none;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .filter-section {
        background: #f8fafc;
        padding: 15px;
        border: 1px solid #e2e8f0;
    }

    .table thead th {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 10px;
        letter-spacing: 0.5px;
        padding: 12px;
    }

    .action-btn {
        padding: 5px 12px;
        border-radius: 5px;
        text-decoration: none;
        font-size: 11px;
        font-weight: 600;
        margin: 0 2px;
        color: white !important;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: none;
        transition: 0.3s;
    }

    .btn-edit {
        background: #3498db;
    }

    .btn-view {
        background: #9b59b6;
    }

    .btn-cancel {
        background: #e74c3c;
    }

    /* Disabled Style */
    .btn-disabled {
        background: #cbd5e1 !important;
        color: #64748b !important;
        cursor: not-allowed;
        opacity: 0.7;
    }

    .action-btn:hover:not(.btn-disabled) {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    .route-badge {
        background: #eef2ff;
        color: #4338ca;
        padding: 3px 8px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 11px;
    }

    .status-active {
        background: #dcfce7;
        color: #15803d;
        font-size: 10px;
        padding: 3px 8px;
        border-radius: 12px;
        font-weight: bold;
    }

    .status-cancelled {
        background: #fee2e2;
        color: #b91c1c;
        font-size: 10px;
        padding: 3px 8px;
        border-radius: 12px;
        font-weight: bold;
    }
</style>

<div class="container-fluid px-4 mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold text-dark mb-0">System Bookings</h4>
            <p class="text-muted small mb-0">Admin Control Panel: Full system management</p>
        </div>
        <span class="badge bg-primary px-3 py-2 shadow-sm">Total: @Model.Count()</span>
    </div>

    <div class="glass-card filter-section mb-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="small fw-bold text-muted">Search Records</label>
                <input type="text" name="searchTerm" class="form-control form-control-sm shadow-none"
                       placeholder="Passenger / Agent / CNIC" value="@Context.Request.Query["searchTerm"]">
            </div>
            <div class="col-md-3">
                <label class="small fw-bold text-muted">Travel Date</label>
                <input type="date" name="travelDate" class="form-control form-control-sm shadow-none"
                       value="@Context.Request.Query["travelDate"]">
            </div>
            <div class="col-md-5 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm px-3 flex-grow-1">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3">Reset</a>
            </div>
        </form>
    </div>

    <div class="glass-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Passenger</th>
                        <th>Booked By</th>
                        <th>Bus/Seat</th>
                        <th>Route</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-center" style="min-width: 230px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold text-dark small">@item.Customer?.CustomerName</div>
                                <div class="text-muted" style="font-size: 11px;">@item.Customer?.IdproofNumber</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-secondary border fw-bold" style="font-size: 10px;">
                                    <i class="fa fa-user me-1"></i>@(item.BookedByNavigation?.FirstName ?? "Admin")
                                </span>
                            </td>
                            <td>
                                <div class="small fw-bold">@item.Bus?.BusNumber</div>
                                <span class="badge bg-light text-dark border small" style="font-size: 10px;">Seat @item.SeatNumber</span>
                            </td>
                            <td>
                                <div class="route-badge text-truncate" style="max-width: 150px;">
                                    @item.StartingPoint <i class="fa fa-arrow-right mx-1" style="font-size: 8px;"></i> @item.DestinationPoint
                                </div>
                            </td>
                            <td class="small">@item.TravelDate.ToString("dd MMM, yyyy")</td>
                            <td>
                                @if (item.BookingStatus == "Booked")
                                {
                                    <span class="status-active">@item.BookingStatus</span>
                                }
                                else
                                {
                                    <span class="status-cancelled">@item.BookingStatus</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.BookingId" class="action-btn btn-view">
                                    <i class="fa fa-eye"></i> View
                                </a>

                            

                                @if (item.BookingStatus != "Cancelled")
                                {
                                    <form asp-action="Cancel" asp-route-id="@item.BookingId" method="post"
                                          onsubmit="return confirm('Confirm cancellation?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn btn-cancel">
                                            <i class="fa fa-times"></i> Cancel
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="action-btn btn-disabled" disabled>
                                        <i class="fa fa-ban"></i> Cancelled
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>