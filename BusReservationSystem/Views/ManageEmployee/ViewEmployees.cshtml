@model IEnumerable<BusReservationSystem.Models.Employee>

@{
    ViewData["Title"] = "Staff Directory";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .glass-card {
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
    }

    .search-section {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 20px;
        border-radius: 12px 12px 0 0;
    }

    .table thead th {
        background-color: #ffffff;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        padding: 15px;
        border-bottom: 2px solid #f1f5f9;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: white !important;
        transition: 0.2s;
        border: none;
    }

    .btn-edit {
        background: #3b82f6;
    }

    .btn-details {
        background: #8b5cf6;
    }

    .btn-delete {
        background: #ef4444;
    }

    .action-btn:hover {
        transform: scale(1.1);
        opacity: 0.9;
    }

    .role-badge {
        background: #f1f5f9;
        color: #475569;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Staff Management</h3>
            <p class="text-muted mb-0">Search and manage your office team</p>
        </div>
        <a asp-action="Register" class="btn btn-primary px-4 py-2 shadow-sm" style="border-radius: 8px;">
            <i class="fa fa-plus me-2"></i>New Employee
        </a>
    </div>

    <div class="glass-card">
        <div class="search-section">
            <form method="get" asp-action="ViewEmployees" class="row g-2">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="fa fa-search"></i>
                        </span>
                        <input type="text" name="searchTerm" class="form-control border-start-0 shadow-none"
                               placeholder="Search by Name, Email, Phone or Role..."
                               value="@Context.Request.Query["searchTerm"]">
                    </div>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-grow-1">
                        <i class="fa fa-filter me-1"></i> Search
                    </button>
                    <a asp-action="ViewEmployees" class="btn btn-outline-secondary px-4">
                        <i class="fa fa-sync-alt me-1"></i> Reset
                    </a>
                </div>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Employee Name</th>
                        <th>Contact Info</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa fa-user-slash d-block mb-2 fs-3"></i>
                                No employees found matching your search.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold text-dark">@item.FirstName @item.LastName</div>
                                <div class="text-muted" style="font-size: 11px;">Age: @item.Age | @item.Gender</div>
                            </td>
                            <td>
                                <div class="small fw-medium">@item.Email</div>
                                <div class="text-muted small">@item.PhoneNumber</div>
                            </td>
                            <td>
                                <span class="role-badge">@item.Role</span>
                            </td>
                            <td>
                                <span class="badge @(item.Status == "Active" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") px-3">
                                    @item.Status
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.EmployeeId" class="action-btn btn-edit" title="Edit Staff">
                                        <i class="fa fa-pen"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.EmployeeId" class="action-btn btn-details" title="Full Profile">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.EmployeeId"
                                       onclick="return confirm('Remove this employee permanently?')"
                                       class="action-btn btn-delete" title="Remove">
                                        <i class="fa fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>