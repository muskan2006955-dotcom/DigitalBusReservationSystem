@{
    ViewData["Title"] = "Security Settings";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container-fluid px-4 mt-5">
    <div class="row justify-content-center">
        <div class="col-xl-5 col-lg-7">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white py-4 text-center">
                    <div class="mb-2">
                        <i class="fas fa-shield-alt fa-3x text-warning"></i>
                    </div>
                    <h4 class="m-0 fw-bold">Update Security Credentials</h4>
                    <p class="small text-white-50 mb-0">Ensure your account stays secure</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted text-uppercase">Current Password</label>
                            <div class="input-group border-bottom border-2">
                                <span class="input-group-text bg-transparent border-0 ps-0"><i class="fas fa-lock text-muted"></i></span>
                                <input type="password" name="currentPassword" class="form-control border-0 shadow-none bg-transparent" placeholder="Enter your current password" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted text-uppercase">New Password</label>
                            <div class="input-group border-bottom border-2">
                                <span class="input-group-text bg-transparent border-0 ps-0"><i class="fas fa-key text-muted"></i></span>
                                <input type="password" name="newPassword" id="newPass" class="form-control border-0 shadow-none bg-transparent" placeholder="Enter new password" required />
                            </div>
                            <div id="passStrength" class="form-text mt-1 small">Use at least 6 characters.</div>
                        </div>

                        <div class="mb-5">
                            <label class="form-label fw-bold small text-muted text-uppercase">Confirm New Password</label>
                            <div class="input-group border-bottom border-2">
                                <span class="input-group-text bg-transparent border-0 ps-0"><i class="fas fa-check-double text-muted"></i></span>
                                <input type="password" name="confirmPassword" class="form-control border-0 shadow-none bg-transparent" placeholder="Repeat new password" required />
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-dark btn-lg rounded-pill shadow fw-bold">
                                <i class="fas fa-save me-2"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light border-0 py-3 text-center">
                    <a asp-action="Index" class="text-decoration-none small fw-bold text-primary">
                        <i class="fas fa-arrow-left me-1"></i> Back to My Profile
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fc;
    }

    .card {
        transition: all 0.3s ease-in-out;
    }

    .input-group:focus-within {
        border-color: #4e73df !important;
    }

    .input-group-text {
        font-size: 1.1rem;
    }

    .form-control::placeholder {
        color: #ccc;
        font-size: 0.9rem;
    }

    .btn-dark {
        background-color: #2c3e50;
        border: none;
    }

        .btn-dark:hover {
            background-color: #1a252f;
            transform: translateY(-2px);
        }
</style>