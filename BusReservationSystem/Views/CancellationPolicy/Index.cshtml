@model IEnumerable<BusReservationSystem.Models.CancellationPolicy>

@{
    ViewData["Title"] = "Cancellation Rules";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .policy-card {
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
        overflow: hidden;
    }

    .table-header-custom {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        padding: 20px;
    }

    .custom-table thead th {
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        padding: 15px;
        letter-spacing: 0.5px;
    }

    .days-badge {
        background: #eff6ff;
        color: #1e40af;
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 13px;
    }

    .deduction-text {
        color: #ef4444;
        font-weight: 800;
        font-size: 16px;
    }

    .action-link {
        font-weight: 600;
        font-size: 12px;
        text-decoration: none;
        padding: 6px 15px;
        border-radius: 6px;
        transition: 0.3s;
    }

    .link-edit {
        background-color: #f1f5f9;
        color: #1e293b;
    }

        .link-edit:hover {
            background-color: #e2e8f0;
        }

    .link-delete {
        color: #ef4444;
    }

        .link-delete:hover {
            background-color: #fef2f2;
        }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Refund & Cancellation Policies</h3>
            <p class="text-muted mb-0">Define how much to deduct based on time before travel</p>
        </div>
        <a asp-action="Create" class="btn btn-dark px-4 py-2 shadow-sm" style="border-radius: 8px; font-weight: 600;">
            Add New Rule
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">
            @TempData["Success"]
        </div>
    }

    <div class="policy-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table">
                <thead>
                    <tr>
                        <th>Minimum Days Before Travel</th>
                        <th>Deduction Rate</th>
                        <th>Status</th>
                        <th class="text-end">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="days-badge">
                                        @item.MinimumDaysBeforeTravel Days or more
                                    </span>
                                </td>
                                <td>
                                    <span class="deduction-text">@item.DeductionPercentage%</span>
                                    <span class="text-muted small"> of total fare</span>
                                </td>
                                <td>
                                    <span class="badge bg-success-subtle text-success border-0 px-2 py-1">Active</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.PolicyId" class="action-link link-edit">
                                            Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.PolicyId" method="post" onsubmit="return confirm('Remove this rule?');" style="display:inline;">
                                            <button type="submit" class="action-link link-delete border-0 bg-transparent">
                                                Remove
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <p class="mb-0">No cancellation policies defined yet.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4 p-3 rounded" style="background: #fffbeb; border: 1px dashed #f59e0b;">
        <p class="mb-0 small text-dark">
            <strong>Pro Tip:</strong> Ensure that policies don't overlap. The system will automatically pick the best matching rule based on the cancellation date.
        </p>
    </div>
</div>