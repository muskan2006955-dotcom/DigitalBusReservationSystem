@model BusReservationSystem.Models.CancellationPolicy

@{
    ViewData["Title"] = "Modify Cancellation Rule";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-wrapper {
        background: #f8fafc;
        padding: 40px 0;
        min-height: 80vh;
    }

    .form-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
    }

    .form-header {
        border-bottom: 2px solid #f1f5f9;
        margin-bottom: 30px;
        padding-bottom: 15px;
    }

        .form-header h2 {
            color: #1e293b;
            font-weight: 800;
            font-size: 22px;
            letter-spacing: -0.5px;
        }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            font-weight: 700;
            margin-bottom: 8px;
            font-size: 13px;
            text-transform: uppercase;
            color: #475569;
            display: block;
        }

    .form-control-custom {
        padding: 12px 16px;
        border-radius: 8px;
        border: 1.5px solid #e2e8f0;
        font-size: 15px;
        width: 100%;
        transition: all 0.3s ease;
        background: #fcfcfc;
    }

        .form-control-custom:focus {
            border-color: #3b82f6;
            background: white;
            outline: none;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }

    .input-helper {
        font-size: 12px;
        color: #64748b;
        margin-top: 6px;
        display: block;
    }

    .btn-group-custom {
        margin-top: 35px;
        padding-top: 20px;
        border-top: 2px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .btn-update-policy {
        background: #3b82f6;
        color: white;
        padding: 12px 30px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-update-policy:hover {
            background: #2563eb;
            transform: translateY(-1px);
        }

    .btn-back-list {
        text-decoration: none;
        padding: 12px 25px;
        border-radius: 8px;
        background: #f1f5f9;
        color: #475569;
        font-weight: 600;
        font-size: 14px;
        transition: 0.3s;
    }

        .btn-back-list:hover {
            background: #e2e8f0;
        }
</style>

<div class="form-wrapper">
    <div class="form-container">
        <div class="form-header">
            <h2>Update Cancellation Rule</h2>
            <p class="text-muted small">Update the deduction percentage for the selected timeframe.</p>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PolicyId" />

            <div class="form-group">
                <label asp-for="MinimumDaysBeforeTravel">Minimum Days Before Travel</label>
                <input asp-for="MinimumDaysBeforeTravel" type="number" class="form-control-custom" placeholder="e.g. 3" required min="0" />
                <span class="input-helper">Is rule ko apply karne ke liye kitne din baaqi hone chahiye?</span>
                <span asp-validation-for="MinimumDaysBeforeTravel" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="DeductionPercentage">Deduction Percentage (%)</label>
                <input asp-for="DeductionPercentage" type="number" step="0.01" class="form-control-custom" placeholder="e.g. 10.00" required min="0" max="100" />
                <span class="input-helper">Puraani rate ko update karein.</span>
                <span asp-validation-for="DeductionPercentage" class="text-danger small"></span>
            </div>

            <div class="btn-group-custom">
                <a asp-action="Index" class="btn-back-list">Discard</a>
                <button type="submit" class="btn-update-policy">Update Policy</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}