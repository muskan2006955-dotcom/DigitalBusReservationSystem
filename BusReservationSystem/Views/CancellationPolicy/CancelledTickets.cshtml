@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Cancelled Tickets";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h2>Cancelled Tickets</h2>
    <span style="font-weight:bold; color:#2563eb;">
        Total Cancelled Tickets: @Model.Count()
    </span>
</div>

<div class="table-container">
    <table class="custom-table">
        <thead>
            <tr>
                <th>Ticket ID</th>
                <th>Passenger</th>
                <th>Bus</th>
                <th>Travel Date</th>
                <th>Cancelled By</th>
                <th>Deduction</th>
                <th>Cancel Date</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TicketId</td>
                        <td>@item.PassengerName</td>
                        <td>@item.BusNumber</td>
                        <td>@item.TravelDate.ToString("dd MMM yyyy")</td>
                        <td>@item.EmployeeName</td>
                        <td>@item.CancellationDeduction?.ToString("C")</td>
                        <td>@item.CancellationDate?.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-action="Deleted" asp-route-id="@item.TicketId"
                               class="btn-delete"
                               onclick="return confirm('Are you sure you want to delete this ticket?');">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">No cancelled tickets found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .table-container {
        overflow-x: auto;
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 700px;
    }

        .custom-table thead {
            background: #1e293b; /* Dark blue header */
            color: white;
        }

        .custom-table th,
        .custom-table td {
            padding: 12px 10px;
            text-align: left;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
        }

        .custom-table tbody tr:hover {
            background: #f1f5f9;
        }

    .btn-action {
        color: #2563eb;
        text-decoration: none;
        margin-right: 8px;
        font-size: 13px;
    }

    .btn-delete {
        color: #dc2626;
        text-decoration: none;
        font-size: 13px;
    }

    @@media (max-width: 768px) {
        .custom-table

    {
        font-size: 12px;
    }

    }
</style>