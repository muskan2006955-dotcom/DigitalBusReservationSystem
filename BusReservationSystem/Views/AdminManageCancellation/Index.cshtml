@model IEnumerable<BusReservationSystem.Models.Booking>

@{
    ViewData["Title"] = "Cancellations Log";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-history me-2"></i>Cancellation History Log</h5>
            <span class="badge bg-white text-danger px-3">Total Records: @Model.Count()</span>
        </div>

        <div class="card-body bg-light border-bottom">
            <form method="get" asp-action="Index">
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="small fw-bold text-muted">Search (Customer Name, Phone, or Bus#)</label>
                        <input type="text" name="searchTerm" class="form-control"
                               placeholder="Enter keywords..." value="@ViewData["CurrentSearch"]">
                    </div>
                    <div class="col-md-3">
                        <label class="small fw-bold text-muted">Filter by Date</label>
                        <input type="date" name="cancelDate" class="form-control"
                               value="@ViewData["CurrentDate"]">
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1 shadow-sm">
                            <i class="fas fa-filter me-1"></i> Apply Filter
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                            <i class="fas fa-sync-alt me-1"></i> Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Booking ID</th>
                        <th>Customer Info</th>
                        <th>Bus & Route</th>
                        <th>Cancelled Date</th>
                        <th class="text-end">Refund Amount</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-info-circle me-1"></i> No cancelled bookings found for the selected criteria.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">#@item.BookingId</td>
                            <td>
                                <div class="fw-bold">@item.Customer?.CustomerName</div>
                                <small class="text-muted">@item.Customer?.PhoneNumber</small>
                            </td>
                            <td>
                                <div class="small fw-bold text-primary">Bus #@item.Bus?.BusNumber</div>
                                <div class="small text-muted">@item.StartingPoint <i class="fas fa-long-arrow-alt-right mx-1"></i> @item.DestinationPoint</div>
                            </td>
                            <td>
                                <div class="small fw-bold">@item.CancellationDate?.ToString("dd-MMM-yyyy")</div>
                                <small class="text-muted">@item.CancellationDate?.ToString("hh:mm tt")</small>
                            </td>
                            <td class="text-end fw-bold text-success">
                                @item.RefundAmount?.ToString("N2")
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info text-white px-3 shadow-sm">
                                    View Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .table tbody td {
        font-size: 0.9rem;
    }

    .btn-info {
        background-color: #17a2b8;
        border-color: #17a2b8;
    }

        .btn-info:hover {
            background-color: #138496;
            border-color: #117a8b;
        }
</style>