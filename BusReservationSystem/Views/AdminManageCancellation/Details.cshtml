@model BusReservationSystem.Models.Booking

@{
    ViewData["Title"] = "Cancellation Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark">
            <i class="fas fa-file-invoice me-2 text-danger"></i>Booking #@Model.BookingId Details
        </h3>
        <a asp-action="Index" class="btn btn-secondary shadow-sm">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold"><i class="fas fa-user me-2"></i>Customer Information</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Full Name</label>
                            <span class="fw-bold">@Model.Customer?.CustomerName</span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Phone Number</label>
                            <span class="fw-bold">@Model.Customer?.PhoneNumber</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold"><i class="fas fa-bus me-2"></i>Trip & Bus Details</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-4 mb-3">
                            <label class="text-muted small d-block">Bus Number</label>
                            <span class="fw-bold text-primary">@Model.Bus?.BusNumber</span>
                        </div>
                        <div class="col-sm-4 mb-3">
                            <label class="text-muted small d-block">Bus Type</label>
                            <span class="badge bg-dark">@Model.Bus?.BusType</span>
                        </div>
                        <div class="col-sm-4 mb-3">
                            <label class="text-muted small d-block">Seat Number</label>
                            <span class="badge bg-info text-dark">Seat #@Model.SeatNumber</span>
                        </div>
                        <div class="col-12">
                            <label class="text-muted small d-block">Route</label>
                            <span class="fw-bold">@Model.StartingPoint <i class="fas fa-arrow-right mx-2 text-muted"></i> @Model.DestinationPoint</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4 bg-danger text-white text-center py-3">
                <div class="card-body">
                    <h5 class="mb-0">STATUS: @Model.BookingStatus</h5>
                    <small>Cancelled on @Model.CancellationDate?.ToString("dd MMM yyyy, hh:mm tt")</small>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold"><i class="fas fa-money-bill-wave me-2"></i>Payment Summary</div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Original Fare:</span>
                        <span class="fw-bold">@Model.FinalAmount?.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-danger">
                        <span>Deduction:</span>
                        <span class="fw-bold">- @((Model.FinalAmount - Model.RefundAmount)?.ToString("C"))</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <span class="h6 fw-bold">Amount Refunded:</span>
                        <span class="h5 fw-bold text-success">@Model.RefundAmount?.ToString("C")</span>
                    </div>
                </div>
                <div class="card-footer bg-light small">
                    <i class="fas fa-user-edit me-1"></i> Processed by: <strong>@Model.BookedByNavigation?.FirstName</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 10px;
    }

    .card-header {
        border-bottom: 1px solid #f0f0f0;
        border-radius: 10px 10px 0 0 !important;
    }

    label {
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>