@{
    ViewData["Title"] = "Security";
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger border-0 shadow-sm">@TempData["Error"]</div>
            }
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-dark text-white py-3 text-center">
                    <h5 class="m-0 fw-bold">Change Password</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        <div class="mb-3">
                            <label class="fw-bold small">Current Password</label>
                            <input type="password" name="currentPassword" class="form-control bg-light border-0" required />
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold small">New Password (Min 4 chars)</label>
                            <input type="password" name="newPassword" class="form-control bg-light border-0" minlength="4" required />
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold small">Confirm Password</label>
                            <input type="password" name="confirmPassword" class="form-control bg-light border-0" required />
                        </div>
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-dark py-2 rounded-pill fw-bold">Update Password</button>
                            <a asp-action="Index" class="btn btn-light py-2 rounded-pill fw-bold">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>